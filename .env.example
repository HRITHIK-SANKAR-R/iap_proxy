# ==========================================
# VanguardGate Environment Configuration
# ==========================================
# INSTRUCTIONS: Copy this file to '.env' and replace values as needed.
# Command: cp .env.example .env
# ==========================================

# --- 🐘 Database Configuration ---
# The connection string for PostgreSQL.
# Local Development: postgres://postgres:postgres@localhost:5432/vanguard_db
# Docker Compose: postgres://postgres:postgres@db:5432/vanguard_db
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vanguard_db

# --- 🌐 Proxy Configuration ---
# The address and port where VanguardGate will listen for incoming traffic.
# Local: 127.0.0.1:6969 | Docker: 0.0.0.0:6969
PROXY_ADDRESS=127.0.0.1:6969

# The internal backend server VanguardGate will forward authenticated traffic to.
# Local: 127.0.0.1:8080 | Docker: host.docker.internal:8080
TARGET_ADDRESS=127.0.0.1:8080

# --- 🔐 Security ---
# The cryptographic secret used to sign and verify JWT tokens.
# IN PRODUCTION: Use a highly secure, randomly generated string (min 32 characters).
JWT_SECRET=change-me-immediately